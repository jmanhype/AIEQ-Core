# AIEQ-Core unified runtime config

# Local control-plane outputs
AIEQ_RUNTIME_DIR=.aieq-runtime
AIEQ_DENARIO_PROJECTS_DIR=.aieq-runtime/denario
AIEQ_AUTORESEARCH_OUTPUT_DIR=.aieq-runtime/autoresearch

# External repos
AIEQ_AUTORESEARCH_REPO=external/autoresearch
AIEQ_DENARIO_REPO=external/denario

# Default execution settings
AIEQ_AUTORESEARCH_BRANCH=main
AIEQ_AUTORESEARCH_TIMEOUT_SECONDS=600
AIEQ_AUTORESEARCH_REMOTE_HOST=
AIEQ_AUTORESEARCH_REMOTE_REPO=
AIEQ_DENARIO_TIMEOUT_SECONDS=1800
AIEQ_DENARIO_MODE=fast
AIEQ_DENARIO_IDEA_LLM=gemini-2.0-flash
AIEQ_DENARIO_METHOD_LLM=gemini-2.0-flash
AIEQ_DENARIO_PAPER_LLM=gemini-2.5-flash
AIEQ_DENARIO_PAPER_JOURNAL=NONE
AIEQ_METHOD_BRIDGE_ENABLED=1
AIEQ_METHOD_BRIDGE_MODEL=gpt-4.1
AIEQ_METHOD_BRIDGE_TIMEOUT_SECONDS=120

# Optional bootstrap default. Can be overridden with --data-description-file.
# AIEQ_DATA_DESCRIPTION_FILE=/absolute/path/to/data_description.md

# Provider credentials used by Denario and the method bridge
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
FUTURE_HOUSE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
